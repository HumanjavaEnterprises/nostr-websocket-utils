{
  "name": "nostr-websocket-utils",
  "version": "0.2.1",
  "description": "WebSocket utilities for Nostr applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "nostr",
    "websocket",
    "utils",
    "maiqr"
  ],
  "author": "Human Java Enterprises",
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.3",
    "nostr-tools": "^2.1.4",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "nostr-tools": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.56.0",
    "typescript": "^4.9.5",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humanjavaenterprises/nostr-websocket-utils.git"
  },
  "bugs": {
    "url": "https://github.com/humanjavaenterprises/nostr-websocket-utils/issues"
  },
  "homepage": "https://github.com/humanjavaenterprises/nostr-websocket-utils#readme",
  "publishConfig": {
    "access": "public"
  }
}
